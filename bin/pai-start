#!/bin/bash
# pai-start — Start the PAI sandbox container
#
# Usage:
#   pai-start                  # Start default instance
#   pai-start --name=v2        # Start named instance

set -euo pipefail

# Source shared instance configuration
_PAI_LIB="$HOME/.local/lib/pai/common.sh"
if [ -f "$_PAI_LIB" ]; then
  source "$_PAI_LIB" "$@"
else
  CONTAINER_NAME="pai" INSTANCE_NAME="pai" INSTANCE_SUFFIX="" _PAI_NAME=""
  BOLD='\033[1m' GREEN='\033[0;32m' YELLOW='\033[1;33m' RED='\033[0;31m' NC='\033[0m'
fi

# Check prerequisites
if ! command -v incus &>/dev/null; then
  echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
  exit 1
fi

# Check if already running
STATUS=$(incus info "$CONTAINER_NAME" 2>/dev/null | grep "^Status:" | awk '{print $2}' || true)
if [ -z "$STATUS" ]; then
  echo -e "${RED}✗${NC} Container '$CONTAINER_NAME' does not exist. Run install.sh first."
  exit 1
fi

if [ "$STATUS" = "RUNNING" ]; then
  echo -e "${YELLOW}⊘${NC} Container '$CONTAINER_NAME' is already running."
  exit 0
fi

echo -e "  Starting PAI sandbox${INSTANCE_SUFFIX:+ ($INSTANCE_NAME)}..."
incus start "$CONTAINER_NAME"

for _i in $(seq 1 30); do
  if incus exec "$CONTAINER_NAME" -- systemctl is-system-running --wait &>/dev/null 2>&1; then
    break
  fi
  sleep 1
done

echo -e "${GREEN}✓${NC} PAI sandbox is running."
echo ""
echo "  ${BOLD}pai-talk${INSTANCE_SUFFIX:+ --name=${_PAI_NAME}}${NC}    — Open a PAI session"
echo "  ${BOLD}pai-shell${INSTANCE_SUFFIX:+ --name=${_PAI_NAME}}${NC}   — Open a shell"
echo "  ${BOLD}pai-status${INSTANCE_SUFFIX:+ --name=${_PAI_NAME}}${NC}  — Check health"
