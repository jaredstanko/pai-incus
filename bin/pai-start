#!/bin/bash
# pai-start — Start the PAI sandbox container
# Starts the Incus container and waits for it to boot.

set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

CONTAINER="pai"

# Check Incus is available
if ! command -v incus &>/dev/null; then
  echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
  exit 1
fi

# Check container exists
if ! incus info "$CONTAINER" &>/dev/null 2>&1; then
  echo -e "${RED}✗${NC} Container '$CONTAINER' does not exist. Run install.sh first."
  exit 1
fi

# Check if already running
STATUS=$(incus info "$CONTAINER" 2>/dev/null | grep "^Status:" | awk '{print $2}')
if [ "$STATUS" = "RUNNING" ]; then
  echo -e "${YELLOW}⊘${NC} Container '$CONTAINER' is already running."
  exit 0
fi

# Start container
echo -e "  Starting PAI sandbox..."
incus start "$CONTAINER"

# Wait for systemd to be ready
for i in $(seq 1 30); do
  if incus exec "$CONTAINER" -- systemctl is-system-running --wait &>/dev/null 2>&1; then
    break
  fi
  sleep 1
done

echo -e "${GREEN}✓${NC} PAI sandbox is running."
echo ""
echo "  ${BOLD}pai-talk${NC}    — Open a PAI session"
echo "  ${BOLD}pai-shell${NC}   — Open a shell"
echo "  ${BOLD}pai-status${NC}  — Check health"
