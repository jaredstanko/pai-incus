#!/bin/bash
# pai-shell — Open a shell inside the PAI sandbox
#
# Usage:
#   pai-shell                  # Shell into default instance
#   pai-shell --name=v2        # Shell into named instance

set -euo pipefail

# Source shared instance configuration
_PAI_LIB="$HOME/.local/lib/pai/common.sh"
if [ -f "$_PAI_LIB" ]; then
  source "$_PAI_LIB" "$@"
  pai_require_container
  pai_ensure_running || exit 1
  echo -e "${GREEN}✓${NC} Sandbox ready."
  exec pai_exec bash -l
else
  # Fallback without common.sh
  CONTAINER_NAME="pai"
  GREEN='\033[0;32m' RED='\033[0;31m' NC='\033[0m'

  if ! command -v incus &>/dev/null; then
    echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
    exit 1
  fi
  if ! incus info "$CONTAINER_NAME" &>/dev/null 2>&1; then
    echo -e "${RED}✗${NC} Container '$CONTAINER_NAME' does not exist. Run install.sh first."
    exit 1
  fi
  exec incus exec "$CONTAINER_NAME" --user 1000 --group 1000 --cwd /home/claude --env HOME=/home/claude -- bash -l
fi
