#!/bin/bash
# pai-status ÔÇö Show PAI sandbox health and version info
# Displays container status, resource usage, and tool versions.

set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

CONTAINER="pai"

# Check Incus is available
if ! command -v incus &>/dev/null; then
  echo -e "${RED}Ô£ù${NC} Incus not found. Run install.sh first."
  exit 1
fi

# Check container exists
if ! incus info "$CONTAINER" &>/dev/null 2>&1; then
  echo -e "${RED}Ô£ù${NC} Container '$CONTAINER' does not exist. Run install.sh first."
  exit 1
fi

echo ""
echo -e "${BOLD}${CYAN}ÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉ${NC}"
echo -e "${BOLD}  PAI Linux ÔÇö Status${NC}"
echo -e "${BOLD}${CYAN}ÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉÔòÉ${NC}"
echo ""

# Container status
STATUS=$(incus info "$CONTAINER" 2>/dev/null | grep "^Status:" | awk '{print $2}')
case "$STATUS" in
  RUNNING)
    echo -e "  Container:  ${GREEN}ÔùÅ RUNNING${NC}"
    ;;
  STOPPED)
    echo -e "  Container:  ${RED}ÔùÅ STOPPED${NC}"
    echo ""
    echo "  Run ${BOLD}pai-start${NC} to start the sandbox."
    exit 0
    ;;
  *)
    echo -e "  Container:  ${YELLOW}ÔùÅ $STATUS${NC}"
    exit 1
    ;;
esac

# Resource usage
echo ""
echo -e "  ${BOLD}Resources${NC}"
CPU_LIMIT=$(incus config get "$CONTAINER" limits.cpu 2>/dev/null || echo "default")
MEM_LIMIT=$(incus config get "$CONTAINER" limits.memory 2>/dev/null || echo "default")
echo "  CPU limit:  $CPU_LIMIT"
echo "  Mem limit:  $MEM_LIMIT"

# Get disk usage
DISK_INFO=$(incus info "$CONTAINER" 2>/dev/null | grep -A2 "root:" || echo "")
if [ -n "$DISK_INFO" ]; then
  echo "  Disk:       $(echo "$DISK_INFO" | grep "Space used" | awk '{print $3, $4}' || echo 'N/A')"
fi

# Uptime
CREATED=$(incus info "$CONTAINER" 2>/dev/null | grep "^Created:" | sed 's/Created: *//')
if [ -n "$CREATED" ]; then
  echo "  Created:    $CREATED"
fi

# Tool versions inside container
echo ""
echo -e "  ${BOLD}Tool Versions${NC}"

VM_CHECK_SCRIPT='
  echo "BUN=$(bun --version 2>/dev/null || echo MISSING)"
  echo "CLAUDE=$(claude --version 2>/dev/null | grep -oE "[0-9.]+" | head -1 || echo MISSING)"
  echo "NODE=$(node --version 2>/dev/null || echo MISSING)"
  echo "PAI=$(test -d /home/claude/.claude/PAI && echo YES || echo NO)"
  echo "COMPANION=$(test -d /home/claude/pai-companion/companion && echo YES || echo NO)"
'
VM_RESULTS=$(incus exec "$CONTAINER" --user 1000 --group 1000 -- bash -lc "$VM_CHECK_SCRIPT" 2>/dev/null || echo "")

get_val() { echo "$VM_RESULTS" | grep "^$1=" | cut -d= -f2- | tr -d '[:space:]'; }

# Load versions.env for comparison
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSIONS_FILE=""
for candidate in "$SCRIPT_DIR/versions.env" "$HOME/pai-linux/versions.env" "$(dirname "$(readlink -f "$0")")/../versions.env"; do
  if [ -f "$candidate" ]; then
    VERSIONS_FILE="$candidate"
    break
  fi
done

if [ -n "$VERSIONS_FILE" ]; then
  source "$VERSIONS_FILE"
fi

show_version() {
  local label="$1"
  local actual="$2"
  local expected="${3:-}"

  if [ -z "$actual" ] || [ "$actual" = "MISSING" ]; then
    printf "  %-14s ${RED}NOT INSTALLED${NC}\n" "$label:"
  elif [ -n "$expected" ] && [ "$actual" = "$expected" ]; then
    printf "  %-14s ${GREEN}%s${NC} (pinned)\n" "$label:" "$actual"
  elif [ -n "$expected" ]; then
    printf "  %-14s ${YELLOW}%s${NC} (expected: %s)\n" "$label:" "$actual" "$expected"
  else
    printf "  %-14s %s\n" "$label:" "$actual"
  fi
}

show_version "Bun" "$(get_val BUN)" "${BUN_VERSION:-}"
show_version "Claude Code" "$(get_val CLAUDE)" "${CLAUDE_CODE_VERSION:-}"
show_version "Node.js" "$(get_val NODE)" ""

PAI_STATUS=$(get_val PAI)
[ "$PAI_STATUS" = "YES" ] && printf "  %-14s ${GREEN}installed${NC}\n" "PAI:" || printf "  %-14s ${RED}not found${NC}\n" "PAI:"

COMP_STATUS=$(get_val COMPANION)
[ "$COMP_STATUS" = "YES" ] && printf "  %-14s ${GREEN}cloned${NC}\n" "Companion:" || printf "  %-14s ${YELLOW}not cloned${NC}\n" "Companion:"

# Audio status
echo ""
echo -e "  ${BOLD}Audio${NC}"
AUDIO_CHECK=$(incus exec "$CONTAINER" --user 1000 --group 1000 -- bash -c '
  if [ -S /tmp/pipewire-0 ]; then echo "PIPEWIRE"; elif [ -S /run/user/1000/pulse/native ]; then echo "PULSE"; else echo "NONE"; fi
' 2>/dev/null || echo "UNKNOWN")

case "$AUDIO_CHECK" in
  PIPEWIRE) echo -e "  Socket:     ${GREEN}PipeWire connected${NC}" ;;
  PULSE)    echo -e "  Socket:     ${GREEN}PulseAudio connected${NC}" ;;
  NONE)     echo -e "  Socket:     ${YELLOW}No audio socket${NC} (is PipeWire running on host?)" ;;
  *)        echo -e "  Socket:     ${RED}Unknown${NC}" ;;
esac

# Mounts
echo ""
echo -e "  ${BOLD}Shared Mounts${NC}"
MOUNT_CHECK=$(incus exec "$CONTAINER" --user 1000 --group 1000 -- bash -c '
  for m in .claude data exchange portal work upstream; do
    test -d "/home/claude/$m" && echo "${m}=OK" || echo "${m}=MISSING"
  done
' 2>/dev/null || echo "")

ALL_OK=true
for mount in .claude data exchange portal work upstream; do
  if echo "$MOUNT_CHECK" | grep -q "${mount}=OK"; then
    printf "  %-14s ${GREEN}mounted${NC}\n" "$mount:"
  else
    printf "  %-14s ${RED}missing${NC}\n" "$mount:"
    ALL_OK=false
  fi
done

echo ""
