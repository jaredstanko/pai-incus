#!/bin/bash
# pai-talk — Launch an interactive PAI session (Claude Code)
#
# Usage:
#   pai-talk                   # New PAI session
#   pai-talk --resume          # Resume a previous Claude Code session
#   pai-talk --claude          # Run plain claude (no PAI launcher)
#   pai-talk --name=v2         # Target a named instance

set -euo pipefail

# Source shared instance configuration
_PAI_LIB="$HOME/.local/lib/pai/common.sh"
if [ -f "$_PAI_LIB" ]; then
  source "$_PAI_LIB" "$@"
else
  CONTAINER_NAME="pai" PORTAL_PORT="8080" INSTANCE_SUFFIX="" INSTANCE_NAME="pai" _PAI_NAME=""
  _PAI_REMAINING_ARGS=("$@")
  BOLD='\033[1m' GREEN='\033[0;32m' RED='\033[0;31m' NC='\033[0m'
fi

# Check prerequisites
if ! command -v incus &>/dev/null; then
  echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
  exit 1
fi

# Ensure container is running
STATUS=$(incus info "$CONTAINER_NAME" 2>/dev/null | grep "^Status:" | awk '{print $2}' || true)
if [ -z "$STATUS" ]; then
  echo -e "${RED}✗${NC} Container '$CONTAINER_NAME' does not exist. Run install.sh first."
  exit 1
fi

if [ "$STATUS" != "RUNNING" ]; then
  echo -e "  Starting PAI sandbox..."
  incus start "$CONTAINER_NAME"
  for _i in $(seq 1 30); do
    if incus exec "$CONTAINER_NAME" -- systemctl is-system-running --wait &>/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
  echo -e "${GREEN}✓${NC} Sandbox started."
fi

# Parse action from remaining args
ACTION=""
for arg in ${_PAI_REMAINING_ARGS[@]+"${_PAI_REMAINING_ARGS[@]}"}; do
  case "$arg" in
    --resume|-r) ACTION="resume" ;;
    --claude|-c) ACTION="claude" ;;
    *) ;;
  esac
done

# Helper for exec into container (use pai_exec if available)
_exec_cmd() {
  if type pai_exec &>/dev/null; then
    exec pai_exec "$@"
  else
    exec incus exec "$CONTAINER_NAME" --user 1000 --group 1000 --cwd /home/claude --env HOME=/home/claude -- "$@"
  fi
}

case "$ACTION" in
  resume)
    echo -e "  Opening session picker..."
    _exec_cmd bash -lc "claude -r"
    ;;
  claude)
    echo -e "  Launching Claude Code..."
    _exec_cmd bash -lc "claude"
    ;;
  *)
    echo -e "  Launching PAI..."
    echo -e "  Portal: ${BOLD}http://localhost:${PORTAL_PORT}${NC}"
    echo ""
    _exec_cmd bash -lc "bun ~/.claude/PAI/Tools/pai.ts"
    ;;
esac
