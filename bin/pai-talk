#!/bin/bash
# pai-talk — Launch an interactive PAI session (Claude Code)
# Opens Claude Code with PAI inside the Incus container.
#
# Usage:
#   pai-talk              # New PAI session
#   pai-talk --resume     # Resume a previous Claude Code session
#   pai-talk --claude     # Run plain claude (no PAI launcher)

set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

CONTAINER="pai"

# Check Incus is available
if ! command -v incus &>/dev/null; then
  echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
  exit 1
fi

# Check container exists
if ! incus info "$CONTAINER" &>/dev/null 2>&1; then
  echo -e "${RED}✗${NC} Container '$CONTAINER' does not exist. Run install.sh first."
  exit 1
fi

# Start container if not running
STATUS=$(incus info "$CONTAINER" 2>/dev/null | grep "^Status:" | awk '{print $2}')
if [ "$STATUS" != "RUNNING" ]; then
  echo -e "  Starting PAI sandbox..."
  incus start "$CONTAINER"
  # Wait for boot
  for i in $(seq 1 30); do
    if incus exec "$CONTAINER" -- systemctl is-system-running --wait &>/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
  echo -e "${GREEN}✓${NC} Sandbox started."
fi

case "${1:-}" in
  --resume|-r)
    echo -e "  Opening session picker..."
    exec incus exec "$CONTAINER" --user 1000 --group 1000 --cwd /home/claude --env HOME=/home/claude -- bash -lc "claude -r"
    ;;
  --claude|-c)
    echo -e "  Launching Claude Code..."
    exec incus exec "$CONTAINER" --user 1000 --group 1000 --cwd /home/claude --env HOME=/home/claude -- bash -lc "claude"
    ;;
  *)
    echo -e "  Launching PAI..."
    echo -e "  Portal: ${BOLD}http://localhost:8080${NC}"
    echo ""
    exec incus exec "$CONTAINER" --user 1000 --group 1000 --cwd /home/claude --env HOME=/home/claude -- bash -lc "bun ~/.claude/PAI/Tools/pai.ts"
    ;;
esac
