# PAI-Linux Version Manifest
# Configuration for dependency installation.
# All install scripts source this file.
#
# Philosophy: install latest versions of fast-moving tools (Bun, Claude Code,
# Playwright). Only pin where a specific major version matters (Node.js).
#
# Review cadence: monthly (security patches, compatibility)

# --- Host Tools -----------------------------------------------------------
INCUS_MIN_VERSION="6.0"
# Incus is installed from Zabbly repo (stable track).

# --- Container Base Image -------------------------------------------------
CONTAINER_IMAGE="images:ubuntu/24.04"
# Official image from images.linuxcontainers.org
# To pin to a specific fingerprint, set CONTAINER_IMAGE_FINGERPRINT below.
# Leave empty to use latest available.
CONTAINER_IMAGE_FINGERPRINT=""

# --- Container Tools ------------------------------------------------------
# Bun, Claude Code, and Playwright install their latest versions.
# Only Node.js is pinned to a major LTS track.
NODE_MAJOR_VERSION="22"

# --- Git Repos ------------------------------------------------------------
PAI_REPO="https://github.com/danielmiessler/PAI.git"
PAI_COMPANION_REPO="https://github.com/chriscantey/pai-companion.git"

# --- apt packages (Ubuntu 24.04 noble) -----------------------------------
# Exact patch versions float with Ubuntu point releases.
APT_PACKAGES="jq fzf ripgrep fd-find sqlite3 tmux bat ffmpeg curl wget imagemagick nmap whois dnsutils net-tools traceroute mtr texlive-latex-base texlive-fonts-recommended pandoc golang-go python3 python3-pip python3-venv build-essential git zip unzip tree htop kitty-terminfo ca-certificates gnupg espeak-ng"

# --- Audio ----------------------------------------------------------------
# Audio passthrough uses PipeWire/PulseAudio socket from host.
# No special versions needed — uses host audio stack.
AUDIO_SOCKET_PATH="/run/user/1000/pipewire-0"
PULSE_SOCKET_PATH="/run/user/1000/pulse/native"
