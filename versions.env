# PAI-Linux Version Manifest
# Single source of truth for all pinned dependency versions.
# All install scripts source this file. Edit versions here, not in scripts.
#
# To update versions:
#   1. Change the version/SHA below
#   2. Run: ./scripts/verify.sh to confirm the new versions work
#   3. Commit the change
#
# Review cadence: monthly (security patches, compatibility)

# --- Host Tools -----------------------------------------------------------
INCUS_MIN_VERSION="6.0"
# Incus is installed from Zabbly repo (stable track).

# --- Container Base Image -------------------------------------------------
CONTAINER_IMAGE="images:ubuntu/24.04"
# Official image from images.linuxcontainers.org
# To pin to a specific fingerprint, set CONTAINER_IMAGE_FINGERPRINT below.
# Leave empty to use latest available.
CONTAINER_IMAGE_FINGERPRINT=""

# --- Container Tools ------------------------------------------------------
BUN_VERSION="1.3.11"
CLAUDE_CODE_VERSION="2.1.89"
NODE_MAJOR_VERSION="18"
PLAYWRIGHT_VERSION="1.59.0"

# --- Git Repos (pinned to commit SHA or tag) ------------------------------
PAI_REPO="https://github.com/danielmiessler/PAI.git"
PAI_COMMIT="HEAD"
# TODO: Pin to specific commit SHA once a stable release is tagged

PAI_COMPANION_REPO="https://github.com/chriscantey/pai-companion.git"
PAI_COMPANION_COMMIT="HEAD"
# TODO: Pin to specific commit SHA once a stable release is tagged

# --- apt packages (Ubuntu 24.04 noble) -----------------------------------
# These are pinned to major versions available in Ubuntu 24.04.
# Exact patch versions float with Ubuntu point releases, which is acceptable
# since the container image itself is pinned above.
APT_PACKAGES="jq fzf ripgrep fd-find sqlite3 tmux bat yt-dlp ffmpeg curl wget imagemagick nmap whois dnsutils net-tools traceroute mtr texlive-latex-base texlive-fonts-recommended pandoc golang-go python3 python3-pip python3-venv build-essential git zip tree nodejs npm"

# --- Audio ----------------------------------------------------------------
# Audio passthrough uses PipeWire/PulseAudio socket from host.
# No special versions needed — uses host audio stack.
AUDIO_SOCKET_PATH="/run/user/1000/pipewire-0"
PULSE_SOCKET_PATH="/run/user/1000/pulse/native"
